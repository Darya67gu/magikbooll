    def change_mode(self):
        """Изменение режима работы"""
        self.current_mode = self.mode_var.get()
        self.status_var.set(f"Режим изменен на: {self.modes[self.current_mode]}")
    
    def get_response_type(self, response):
        """Определить тип ответа"""
        response_lower = response.lower()
        
        positive_words = ["да", "бесспорно", "определённо", "уверен", "вероятнее", 
                         "хорошие", "согласн", "можно", "стоит", "благоприят"]
        negative_words = ["нет", "не думай", "сомнительно", "не очень", "отказ", "плох"]
        neutral_words = ["спроси", "попробуй", "позже", "нельзя", "не ясно", "подумай", "может"]
        
        if any(word in response_lower for word in positive_words):
            return "positive"
        elif any(word in response_lower for word in negative_words):
            return "negative"
        elif any(word in response_lower for word in neutral_words):
            return "neutral"
        else:
            return "mysterious"
    
    def get_answer(self):
        """Получить ответ на вопрос"""
        question = self.question_entry.get().strip()
        
        if not question:
            messagebox.showwarning("Внимание", "Пожалуйста, введите вопрос!")
            return
        
        # Визуальная обратная связь
        self.ask_button.config(state=tk.DISABLED)
        self.question_entry.config(state=tk.DISABLED)
        self.status_var.set("🎱 Магический шар думает...")
        self.root.update()
        
        # Выбор ответа в зависимости от режима
        if self.current_mode == "standard":
            response = random.choice(self.standard_responses)
        elif self.current_mode == "funny":
            response = random.choice(self.funny_responses)
        elif self.current_mode == "poetic":
            response = random.choice(self.poetic_responses)
        elif self.current_mode == "mix":
            all_responses = self.standard_responses + self.funny_responses + self.poetic_responses
            response = random.choice(all_responses)
        
        # Определение типа ответа
        response_type = self.get_response_type(response)
        
        # Цвета для разных типов ответов
        colors = {
            "positive": "#2ecc71",  # Зеленый
            "negative": "#e74c3c",  # Красный
            "neutral": "#f39c12",   # Оранжевый
            "mysterious": "#9b59b6" # Фиолетовый
        }
        
        # Анимация задержки
        self.root.after(1000, lambda: self.display_answer(response, colors[response_type]))
        
        # Сохранение в историю
        self.save_to_history(question, response, response_type)
        
        # Обновление истории в интерфейсе
        self.update_history_display()
    
    def display_answer(self, response, color):
        """Отображение ответа с анимацией"""
        self.answer_text.config(state=tk.NORMAL)
        self.answer_text.delete(1.0, tk.END)
        self.answer_text.insert(1.0, response)
        self.answer_text.config(fg=color)
        self.answer_text.config(state=tk.DISABLED)
        
        # Возвращаем доступ к элементам
        self.ask_button.config(state=tk.NORMAL)
        self.question_entry.config(state=tk.NORMAL)
        self.question_entry.delete(0, tk.END)
        self.question_entry.focus()
        
        self.status_var.set("Готов к следующему вопросу!")
    
    def save_to_history(self, question, response, response_type):
        """Сохранить вопрос и ответ в историю"""
        entry = {
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "question": question,
            "response": response,
            "type": response_type,
            "mode": self.current_mode
        }
        self.history.append(entry)
        
        # Сохраняем в файл (последние 50 записей)
        if len(self.history) > 50:
            self.history = self.history[-50:]
        
        self.save_history()
    
    def save_history(self):
        """Сохранить историю в файл"""
        try:
            with open("magic_ball_history.json", "w", encoding="utf-8") as f:
                json.dump(self.history, f, ensure_ascii=False, indent=2)
        except:
            pass
    
    def load_history(self):
        """Загрузить историю из файла"""
        try:
            if os.path.exists("magic_ball_history.json"):
                with open("magic_ball_history.json", "r", encoding="utf-8") as f:
                    self.history = json.load(f)
        except:
            self.history = []
    
    def update_history_display(self):
        """Обновить отображение истории"""
        self.history_text.config(state=tk.NORMAL)
        self.history_text.delete(1.0, tk.END)
        
        if not self.history:
            self.history_text.insert(1.0, "История пуста. Задайте несколько вопросов!")
        else:
            # Показываем последние 10 записей
            recent = self.history[-10:] if len(self.history) > 10 else self.history
            
            for entry in reversed(recent):
                time_str = entry['timestamp'][11:16]  # Только время
                question = entry['question']
                
                if len(question) > 30:
                    question = question[:27] + "..."
                
                self.history_text.insert(1.0, 
                    f"[{time_str}] {question}\n"
                    f"    Ответ: {entry['response']}\n\n"
                )
        
        self.history_text.config(state=tk.DISABLED)
    
    def show_history(self):
        """Показать полную историю"""
        if not self.history:
            messagebox.showinfo("История", "История пуста. Задайте несколько вопросов!")
            return
        
        history_window = tk.Toplevel(self.root)
        history_window.title("📜 Полная история")
        history_window.geometry("600x400")
        history_window.configure(bg='#2c3e50')
        
        # Текстовое поле с историей
        text_widget = scrolledtext.ScrolledText(
            history_window,
            font=("Arial", 10),
            bg='#34495e',
            fg='#ecf0f1',
            wrap=tk.WORD
        )
        text_widget.pack(expand=True, fill=tk.BOTH, padx=10, pady=10)
        
        # Заполняем историю
        for entry in reversed(self.history):
            date_str = entry['timestamp'][:10]
            time_str = entry['timestamp'][11:16]
            question = entry['question']
            
            # Цвет в зависимости от типа ответа
            colors = {
                "positive": "#2ecc71",
                "negative": "#e74c3c",
                "neutral": "#f39c12",
                "mysterious": "#9b59b6"
            }
            
            text_widget.insert(tk.END, 
                f"📅 {date_str} {time_str}\n"
                f"❓ Вопрос: {question}\n"
            )
            
            # Вставляем ответ с цветом
            text_widget.insert(tk.END, f"🎱 Ответ: ")
            text_widget.insert(tk.END, entry['response'] + "\n", f"color_{entry['type']}")
            text_widget.insert(tk.END, f"🔧 Режим: {self.modes.get(entry['mode'], 'Неизвестно')}\n")
            text_widget.insert(tk.END, "─" * 50 + "\n\n")
        
        # Настройка тегов для цветов
        for resp_type, color in colors.items():
            text_widget.tag_config(f"color_{resp_type}", foreground=color)
        
        text_widget.config(state=tk.DISABLED)
    
    def show_statistics(self):
        """Показать статистику"""
        if not self.history:
            messagebox.showinfo("Статистика", "Нет данных для статистики")
            return
        
        total = len(self.history)
        
        # Считаем типы ответов
        types = {'positive': 0, 'negative': 0, 'neutral': 0, 'mysterious': 0}
        for entry in self.history:
            types[entry['type']] = types.get(entry['type'], 0) + 1
        
        # Создаем окно статистики
        stats_window = tk.Toplevel(self.root)
        stats_window.title("📊 Статистика")
        stats_window.geometry("400x300")
        stats_window.configure(bg='#2c3e50')
        
        # Фрейм для статистики
        stats_frame = tk.Frame(stats_window, bg='#2c3e50')
        stats_frame.pack(expand=True, fill=tk.BOTH, padx=20, pady=20)
        
        # Заголовок
        tk.Label(
            stats_frame,
            text="📊 СТАТИСТИКА МАГИЧЕСКОГО ШАРА",
            font=("Arial", 14, "bold"),
            bg='#2c3e50',
            fg='#3498db'
        ).pack(pady=(0, 20))
        
        # Общая информация
        info_frame = tk.Frame(stats_frame, bg='#2c3e50')
        info_frame.pack(fill=tk.X, pady=5)
        
        tk.Label(
            info_frame,
            text=f"Всего вопросов: {total}",
            font=("Arial", 11, "bold"),
            bg='#2c3e50',
            fg='#ecf0f1'
        ).pack()
        
        # Статистика по типам
        stats_data = [
            ("Положительных", types['positive'], "#2ecc71"),
            ("Отрицательных", types['negative'], "#e74c3c"),
            ("Нейтральных", types['neutral'], "#f39c12"),
            ("Загадочных", types['mysterious'], "#9b59b6")
        ]
        
        for label, count, color in stats_data:
            frame = tk.Frame(stats_frame, bg='#2c3e50')
            frame.pack(fill=tk.X, pady=3)
            
            percentage = (count / total * 100) if total > 0 else 0
            
            tk.Label(
                frame,
                text=f"{label}:",
                font=("Arial", 10),
                bg='#2c3e50',
                fg='#ecf0f1',
                width=15,
                anchor=tk.W
            ).pack(side=tk.LEFT)
            
            tk.Label(
                frame,
                text=f"{count} ({percentage:.1f}%)",
                font=("Arial", 10, "bold"),
                bg='#2c3e50',
                fg=color
            ).pack(side=tk.LEFT)
        
        # Кнопка закрытия
        tk.Button(
            stats_window,
            text="Закрыть",
            command=stats_window.destroy,
            bg='#34495e',
            fg='#ecf0f1',
            font=("Arial", 10),
            padx=20,
            pady=5
        ).pack(pady=20)
    
    def clear_history(self):
        """Очистить историю"""
        if messagebox.askyesno("Очистка истории", "Вы уверены, что хотите очистить всю историю?"):
            self.history = []
            self.save_history()
            self.update_history_display()
            self.status_var.set("История очищена!")
    
